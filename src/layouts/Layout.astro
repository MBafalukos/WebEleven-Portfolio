---
import "../styles/global.css";
import Header from "$lib/components/Header.svelte";
import Footer from "$lib/components/Footer.svelte";
import SmoothScroll from "$lib/components/SmoothScroll.svelte";
interface Props {
  locale?: "en" | "gr";
}

const { locale = "en" } = Astro.props;
const langAttr = locale === "gr" ? "el" : "en";
const metaDescription =
  locale === "gr"
    ? "Michalis Bafalukos — full-stack developer. Δες projects με React, Svelte, Astro, Tailwind και Python και επικοινώνησε μαζί μου."
    : "Michalis Bafalukos — full-stack developer building modern web apps with React, Svelte, Astro, Tailwind CSS, and Python. Explore projects and get in touch.";
---

<html lang={langAttr}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={metaDescription} />
    <title>Astro Portfolio</title>
  </head>
  <body class="bg-[#000103] text-[#FFFFFA]">
    <SmoothScroll client:only="svelte" />
    <Header initialLocale={locale} client:load />
    <main>
      <slot />
    </main>
    <Footer locale={locale} client:visible />
  </body>
</html>
